{
  "name": "claude-stack-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Reproducible validation/benchmarking monorepo proving that awesome-claude-token-stack and ClaudeMaxPower deliver measurable outcomes.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./apps/* run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "test": "vitest run && pnpm --filter @lab/web-dashboard run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:dashboard": "pnpm --filter @lab/web-dashboard run test",
    "scenario": "pnpm --filter @lab/cli run start",
    "scenario:001": "pnpm --filter @lab/cli run start run 001",
    "scenario:all": "pnpm --filter @lab/cli run start run all",
    "metrics": "node scripts/metrics.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^8",
    "@stryker-mutator/vitest-runner": "^8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.3.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^8.0.9",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "fastify": "^5"
  }
}
