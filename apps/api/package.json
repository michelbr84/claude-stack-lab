{
  "name": "@lab/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "lab-api": "./src/bin.ts"
  },
  "scripts": {
    "build": "tsc -b",
