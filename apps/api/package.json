  },
  "dependencies": {
    "@lab/shared": "workspace:*",
    "@lab/reporting": "workspace:*",
    "@lab/scoring-engine": "workspace:*",
    "@lab/runner": "workspace:*",
    "fastify": "^5"
  }
}
